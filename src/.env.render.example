# Render 本番用環境変数のテンプレート（コミット可。実値は Render ダッシュボードの Environment に入力）
# 使い方: コピーして Render にキーごと登録するか、ローカル検証のみなら .env にリネームしないこと（誤コミット防止）

APP_NAME=SpotRem
APP_ENV=production
# ローカルで php artisan key:generate --show の値を1本決め、Render にそのまま設定（デプロイごとに変えない）
APP_KEY=base64:REPLACE_WITH_ARTISAN_KEY_GENERATE_SHOW
APP_DEBUG=false
# 実サービス URL（末尾スラッシュなし推奨）。LINE Webhook・LIFF・署名付き URL と完全一致させる
APP_URL=https://your-service-name.onrender.com
APP_TIMEZONE=Asia/Tokyo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Render のログは stderr が追いやすい
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# PostgreSQL（Render で DB を Web Service に Link すると DATABASE_URL が自動注入されることが多い）
DB_CONNECTION=pgsql
# Link 時は未設定でも可。手入力する場合は Internal/External Database URL を貼る
# DATABASE_URL=postgresql://...
# DB_URL は未使用なら省略可（pgsql は DB_URL 無しで DATABASE_URL にフォールバック）
# DB_URL=
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# 本番でメール送信する場合は SMTP 等に差し替え
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

LINE_LIFF_CHANNEL_ID=
LINE_LIFF_ID=
LINE_LIFF_ID_TROUBLE=

LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Render ではファイルが消えるため、Secret File マウントパスを指定するか BASE64 を推奨
GOOGLE_CALENDAR_CREDENTIALS_PATH=
# サービスアカウント JSON を1行 base64 した値（設定時は PATH より優先）
GOOGLE_CALENDAR_CREDENTIALS_BASE64=
GOOGLE_CALENDAR_SLOT_TITLE_KEYWORD=対応可能

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_TROUBLE_FOLDER=spotrem/trouble
CLOUDINARY_TROUBLE_MAX_KB=51200
CLOUDINARY_INVOICE_FOLDER=spotrem/invoices
CLOUDINARY_INVOICE_MAX_KB=20480
