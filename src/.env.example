APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Tokyo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# verify API の client_id。Developers「チャネル基本設定」のチャネルID（数値）。※LIFF ID ではない
LINE_LIFF_CHANNEL_ID=
# 入居者登録 LIFF（Endpoint 例: …/liff/resident-register）。リッチメニュー: https://liff.line.me/（このID）
LINE_LIFF_ID=
# トラブル報告 LIFF（Endpoint 例: …/liff/trouble-report）。空なら LINE_LIFF_ID と同じ
LINE_LIFF_ID_TROUBLE=

# Messaging API（プッシュ通知・Webhook 署名）。Bot チャネルの長期チャネルアクセストークン・チャネルシークレット
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Calendar（業者空き）。次のいずれか。
# A) サービスアカウント JSON のパス（例: storage/app/google-calendar-sa.json）。Render Secret File なら /etc/secrets/ファイル名
GOOGLE_CALENDAR_CREDENTIALS_PATH=
# B) サービスアカウント JSON 全体を base64（改行なし）。設定すると A より優先（Render の環境変数に載せやすい）
# GOOGLE_CALENDAR_CREDENTIALS_BASE64=
# イベントタイトルに含まれる文字で「空き枠」として一覧に出す。未設定時は「対応可能」。空にすると全イベントを枠として返す
GOOGLE_CALENDAR_SLOT_TITLE_KEYWORD=対応可能

# Cloudinary（トラブル添付）
# Cloud name はダッシュボードの「Cloud name」と完全一致（コピペ推奨）。アプリ側で小文字化するが、綴り誤りは直らない
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_TROUBLE_FOLDER=spotrem/trouble
# アップロード1ファイルあたりの最大 KB（既定 51200 ≒ 50MB）
CLOUDINARY_TROUBLE_MAX_KB=51200
# オプション請求書 PDF（Cloudinary raw）。未設定時は spotrem/invoices
CLOUDINARY_INVOICE_FOLDER=spotrem/invoices
# 請求書 PDF 1 ファイルあたりの最大 KB（既定 20480 ≒ 20MB）
CLOUDINARY_INVOICE_MAX_KB=20480
